;;
;; Routing of a Contract ProviderContract
;;

;; message opcode reader utility: only binary receivers
;; Returns 32 bit message opcode, otherwise throws the "Invalid incoming message" exit code
(slice, int) ~load_opcode_internal(slice s) asm( -> 1 0) "32 LDUQ 130 THROWIFNOT";

() recv_internal(int msg_value, cell in_msg_cell, slice in_msg) impure {
    
    ;; Context
    var cs = in_msg_cell.begin_parse();
    cs~skip_bits(2);
    var msg_bounceable = cs~load_int(1);
    var msg_bounced = cs~load_int(1);
    slice msg_sender_addr = cs~load_msg_addr();
    __tact_context = (msg_bounceable, msg_sender_addr, msg_value, cs);
    __tact_context_sender = msg_sender_addr;
    
    ;; Load contract data
    var ($self'owner, $self'commissionBps, $self'stake, $self'totalBets, $self'totalPayouts, $self'gameCount) = $ProviderContract$_contract_load();
    
    ;; Handle bounced messages
    if (msg_bounced) { return (); }
    var op = in_msg~load_opcode_internal();
    ;; Receive AddStake message
    if (op == 0x10) {
        var $msg = empty_tuple();
        $self'stake = ($self'stake + $Context$_get_value(__tact_context_get()));
        $ProviderContract$_contract_store(($self'owner, $self'commissionBps, $self'stake, $self'totalBets, $self'totalPayouts, $self'gameCount));
        return ();
    }
    
    ;; Receive WithdrawStake message
    if (op == 0x11) {
        var $msg'amount = in_msg~load_varuint16();
        throw_unless(35499, ( equal_slices_bits(__tact_context_get_sender(), $self'owner) ));
        throw_unless(11977, ($msg'amount > 0));
        throw_unless(21245, ($self'stake >= $msg'amount));
        $self'stake = ($self'stake - $msg'amount);
        $global_send($SendParameters$_constructor_to_value_body($self'owner, $msg'amount, null()));
        $ProviderContract$_contract_store(($self'owner, $self'commissionBps, $self'stake, $self'totalBets, $self'totalPayouts, $self'gameCount));
        return ();
    }
    
    ;; Receive SetCommission message
    if (op == 0x12) {
        var $msg'commissionBps = in_msg~load_uint(16);
        throw_unless(35499, ( equal_slices_bits(__tact_context_get_sender(), $self'owner) ));
        throw_unless(20824, ($msg'commissionBps <= 10000));
        $self'commissionBps = $msg'commissionBps;
        $ProviderContract$_contract_store(($self'owner, $self'commissionBps, $self'stake, $self'totalBets, $self'totalPayouts, $self'gameCount));
        return ();
    }
    
    ;; Receive PlaceBet message
    if (op == 0x1) {
        var $msg'nonce = in_msg~load_uint(64);
        var $msg'clientSeed = in_msg~load_ref();
        var $msg'commitment = in_msg~load_ref();
        var $msg'serverSeedHash = in_msg~load_ref();
        throw_unless(43379, ($self'stake > 0));
        int $betValue = $Context$_get_value(__tact_context_get());
        throw_unless(56646, ($betValue > 0));
        $self'totalBets = ($self'totalBets + $betValue);
        $self'gameCount = ($self'gameCount + 1);
        $ProviderContract$_contract_store(($self'owner, $self'commissionBps, $self'stake, $self'totalBets, $self'totalPayouts, $self'gameCount));
        return ();
    }
    
    ;; Receive RevealSeed message
    if (op == 0x2) {
        var $msg'nonce = in_msg~load_uint(64);
        var $msg'serverSeed = in_msg~load_ref();
        int $outcome = $global_calculateResult($Cell$_fun_beginParse($msg'serverSeed), $Cell$_fun_beginParse($msg'serverSeed), $msg'nonce);
        int $rawMultiplier = $global_getMultiplier($outcome);
        int $multiplier = (($rawMultiplier * (10000 - $self'commissionBps)) / 10000);
        int $payout = $global_calcPayout($Context$_get_value(__tact_context_get()), $multiplier);
        $self'totalPayouts = ($self'totalPayouts + $payout);
        $global_send($SendParameters$_constructor_to_value_body(__tact_context_get_sender(), $payout, $GameResult$_store_cell($GameResult$_constructor_outcome_multiplier_payout_serverSeed_nonce($outcome, $multiplier, $payout, $msg'serverSeed, $msg'nonce), begin_cell())));
        $ProviderContract$_contract_store(($self'owner, $self'commissionBps, $self'stake, $self'totalBets, $self'totalPayouts, $self'gameCount));
        return ();
    }
    
    ;; Throw if not handled
    throw(130);
}
