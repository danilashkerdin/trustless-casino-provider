;;
;; Routing of a Contract ProviderContract
;;

;; message opcode reader utility: only binary receivers
;; Returns 32 bit message opcode, otherwise throws the "Invalid incoming message" exit code
(slice, int) ~load_opcode_internal(slice s) asm( -> 1 0) "32 LDUQ 130 THROWIFNOT";

() recv_internal(int msg_value, cell in_msg_cell, slice in_msg) impure {
    
    ;; Context
    var cs = in_msg_cell.begin_parse();
    cs~skip_bits(2);
    var msg_bounceable = cs~load_int(1);
    var msg_bounced = cs~load_int(1);
    slice msg_sender_addr = cs~load_msg_addr();
    __tact_context = (msg_bounceable, msg_sender_addr, msg_value, cs);
    __tact_context_sender = msg_sender_addr;
    
    ;; Load contract data
    var ($self'owner, $self'commissionBps, $self'stake, $self'totalBets, $self'totalPayouts, $self'totalCommission, $self'gameCount, $self'pendingSender, $self'pendingBetAmount, $self'pendingGuess, $self'pendingSeedHash) = $ProviderContract$_contract_load();
    
    ;; Handle bounced messages
    if (msg_bounced) { return (); }
    var op = in_msg~load_opcode_internal();
    ;; Receive AddStake message
    if (op == 0x10) {
        var $msg = empty_tuple();
        $self'stake = ($self'stake + $Context$_get_value(__tact_context_get()));
        $ProviderContract$_contract_store(($self'owner, $self'commissionBps, $self'stake, $self'totalBets, $self'totalPayouts, $self'totalCommission, $self'gameCount, $self'pendingSender, $self'pendingBetAmount, $self'pendingGuess, $self'pendingSeedHash));
        return ();
    }
    
    ;; Receive WithdrawStake message
    if (op == 0x11) {
        var $msg'amount = in_msg~load_varuint16();
        throw_unless(35499, ( equal_slices_bits(__tact_context_get_sender(), $self'owner) ));
        throw_unless(11977, ($msg'amount > 0));
        throw_unless(21245, ($self'stake >= $msg'amount));
        $self'stake = ($self'stake - $msg'amount);
        $global_send($SendParameters$_constructor_to_value_body($self'owner, $msg'amount, null()));
        $ProviderContract$_contract_store(($self'owner, $self'commissionBps, $self'stake, $self'totalBets, $self'totalPayouts, $self'totalCommission, $self'gameCount, $self'pendingSender, $self'pendingBetAmount, $self'pendingGuess, $self'pendingSeedHash));
        return ();
    }
    
    ;; Receive SetCommission message
    if (op == 0x12) {
        var $msg'commissionBps = in_msg~load_uint(16);
        throw_unless(35499, ( equal_slices_bits(__tact_context_get_sender(), $self'owner) ));
        throw_unless(20824, ($msg'commissionBps <= 10000));
        $self'commissionBps = $msg'commissionBps;
        $ProviderContract$_contract_store(($self'owner, $self'commissionBps, $self'stake, $self'totalBets, $self'totalPayouts, $self'totalCommission, $self'gameCount, $self'pendingSender, $self'pendingBetAmount, $self'pendingGuess, $self'pendingSeedHash));
        return ();
    }
    
    ;; Receive WithdrawCommission message
    if (op == 0x13) {
        var $msg'amount = in_msg~load_varuint16();
        throw_unless(35499, ( equal_slices_bits(__tact_context_get_sender(), $self'owner) ));
        throw_unless(11977, ($msg'amount > 0));
        throw_unless(27584, ($self'totalCommission >= $msg'amount));
        $self'totalCommission = ($self'totalCommission - $msg'amount);
        $global_send($SendParameters$_constructor_to_value_body($self'owner, $msg'amount, null()));
        $ProviderContract$_contract_store(($self'owner, $self'commissionBps, $self'stake, $self'totalBets, $self'totalPayouts, $self'totalCommission, $self'gameCount, $self'pendingSender, $self'pendingBetAmount, $self'pendingGuess, $self'pendingSeedHash));
        return ();
    }
    
    ;; Receive PlaceBet message
    if (op == 0x1) {
        var $msg'nonce = in_msg~load_uint(64);
        var $msg'guess = in_msg~load_uint(8);
        var $msg'clientSeed = in_msg~load_ref();
        var $msg'serverSeedHash = in_msg~load_uint(256);
        throw_unless(11191, ($self'stake > 0));
        throw_unless(62748, ( (($msg'guess >= 1)) ? (($msg'guess <= 6)) : (false) ));
        int $betValue = $Context$_get_value(__tact_context_get());
        throw_unless(56646, ($betValue > 0));
        throw_unless(8045, ($self'pendingBetAmount == 0));
        $self'pendingSender = __tact_context_get_sender();
        $self'pendingBetAmount = $betValue;
        $self'pendingGuess = $msg'guess;
        $self'pendingSeedHash = $msg'serverSeedHash;
        $self'totalBets = ($self'totalBets + $betValue);
        $self'gameCount = ($self'gameCount + 1);
        $ProviderContract$_contract_store(($self'owner, $self'commissionBps, $self'stake, $self'totalBets, $self'totalPayouts, $self'totalCommission, $self'gameCount, $self'pendingSender, $self'pendingBetAmount, $self'pendingGuess, $self'pendingSeedHash));
        return ();
    }
    
    ;; Receive RevealSeed message
    if (op == 0x2) {
        var $msg'nonce = in_msg~load_uint(64);
        var $msg'serverSeed = in_msg~load_ref().begin_parse();
        var $msg'serverSeedHash = in_msg~load_uint(256);
        var $msg'guess = in_msg~load_uint(8);
        var $msg'clientSeed = in_msg~load_ref();
        throw_unless(28115, ($self'stake > 0));
        throw_unless(27815, ($self'pendingBetAmount > 0));
        int $computedHash = __tact_sha256($msg'serverSeed);
        throw_unless(15371, ($computedHash == $self'pendingSeedHash));
        int $roll = $global_diceRoll($msg'serverSeed, $Cell$_fun_beginParse($msg'clientSeed), $msg'nonce);
        int $win = ($roll == $self'pendingGuess);
        int $grossPayout = 0;
        int $commissionTaken = 0;
        int $netPayout = 0;
        if ($win) {
            $grossPayout = ($self'pendingBetAmount * 6);
            $commissionTaken = (($grossPayout * $self'commissionBps) / 10000);
            if (($commissionTaken > $grossPayout)) {
                $commissionTaken = $grossPayout;
            }
            $netPayout = ($grossPayout - $commissionTaken);
            throw_unless(21245, ($self'stake >= $netPayout));
            $self'stake = ($self'stake - $netPayout);
            $self'totalPayouts = ($self'totalPayouts + $netPayout);
            $self'totalCommission = ($self'totalCommission + $commissionTaken);
        }
        $self'pendingBetAmount = 0;
        $self'pendingGuess = 0;
        $self'pendingSeedHash = 0;
        cell $replyBody = $Builder$_fun_endCell(store_uint($Builder$_fun_storeSlice($Builder$_fun_storeCoins($Builder$_fun_storeCoins($Builder$_fun_storeCoins(store_uint($Builder$_fun_storeBit($win, store_uint($global_beginCell(), $roll, 32)), ($win ? 60000 : 0), 16), $grossPayout), $commissionTaken), $netPayout), $msg'serverSeed), $msg'nonce, 64));
        $global_send($SendParameters$_constructor_to_value_body($self'pendingSender, $netPayout, $replyBody));
        $ProviderContract$_contract_store(($self'owner, $self'commissionBps, $self'stake, $self'totalBets, $self'totalPayouts, $self'totalCommission, $self'gameCount, $self'pendingSender, $self'pendingBetAmount, $self'pendingGuess, $self'pendingSeedHash));
        return ();
    }
    
    ;; Receive SlashStake message
    if (op == 0x30) {
        var $msg'nonce = in_msg~load_uint(64);
        var $msg'expectedHash = in_msg~load_uint(256);
        var $msg'actualServerSeed = in_msg~load_ref().begin_parse();
        var $msg'clientSeed = in_msg~load_ref();
        var $msg'betAmount = in_msg~load_varuint16();
        var $msg'guess = in_msg~load_uint(8);
        int $computedHash = __tact_sha256($msg'actualServerSeed);
        throw_unless(3006, ($computedHash != $msg'expectedHash));
        int $owed = ($msg'betAmount * 6);
        if (($owed > $self'stake)) {
            $owed = $self'stake;
        }
        $self'stake = ($self'stake - $owed);
        $self'totalPayouts = ($self'totalPayouts + $owed);
        $global_send($SendParameters$_constructor_to_value_body(__tact_context_get_sender(), $owed, null()));
        $ProviderContract$_contract_store(($self'owner, $self'commissionBps, $self'stake, $self'totalBets, $self'totalPayouts, $self'totalCommission, $self'gameCount, $self'pendingSender, $self'pendingBetAmount, $self'pendingGuess, $self'pendingSeedHash));
        return ();
    }
    
    ;; Throw if not handled
    throw(130);
}
